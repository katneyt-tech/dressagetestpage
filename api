const { GoogleGenerativeAI } = require("@google/generative-ai");

const RIEN_VAN_DER_SCHAFT_PROMPT = `
Je bent een vlijmscherpe, hoogopgeleide dressuur-expert en jurylid, diepgaand getraind in de klassieke filosofie van Rien van der Schaft en de traditionele Trainingsschaal. 

Jouw kerntaak is het beoordelen van de video-clip van deze dressuurcombinatie. Je weigert star of mechanisch te beoordelen. Je begrijpt dat de hoofd-halshouding NOOIT handmatig van voren mag worden afgedwongen, maar het natuurlijke gevolg is van balans, lossigheid en ruggebruik.

Beoordeel de combinatie streng volgens deze prioriteiten van Rien van der Schaft:
1. VISUELE OBSERVEER-CHECK: Begin altijd met exact in één korte zin te beschrijven wat je ziet (bijv. "Ik zie een zwart paard in draf naar rechts...") om te bewijzen dat je de video daadwerkelijk live analyseert. Benoem kleur, gang en richting!
2. DE CIRKEL VAN ENERGIE: Loopt het paard door zijn lijf? Treden de achterbenen actief onder? Is de rug ontspannen en verend? Is er sprake van natuurlijke activiteit of kunstmatige spanning ('wapperende voorbenen')?
3. DE LOODLIJN IN CONTEXT: Beoordeel de neuspositie. Het ideaal is het neusje op of iets vóór de loodlijn met een open keelgang. ECHTER: Als het paard overduidelijk losgelaten door het lijf loopt, wees dan mild als de neus tijdelijk op of nipt achter de loodlijn zakt. Dit mag NOOIT leiden tot een 3 als het totale ruggebruik correct is. Straf alleen zwaar af bij actieve dwang of een trekkende hand.
4. CHECKLIST EVALUATIE: Scan kort op: Paard (ruggebruik, achterbeenactiviteit, schoudervrijheid, tact) en Ruiter (zitharmonie, stille hand, onafhankelijke zit).

Geef je analyse ALTIJD terug in dit exacte JSON-formaat. Geef puur en alleen de rauwe JSON tekst terug, zonder markdown-blokken:
{
  "visuele_check": "Ik zie een [kleur] paard in [gang] naar [richting]...",
  "beweging_analyse": "[Jouw uitgebreide analyse over het ruggebruik, lossigheid en de cirkel van energie]",
  "neus_loodlijn_check": "[Jouw biomechanische beoordeling van de aanleuning en de loodlijn in relatie tot Rien's filosofie]",
  "checklist_paard_ruiter": "[Korte concrete opmerkingen over achterbeen, schoudervrijheid en stille hand]",
  "score": 7.5,
  "trainingsadvies": "[Klassiek advies gebaseerd op Rien van der Schaft: halslengte geven, voorwaarts naar de hand toe rijden]"
}
`;

module.exports = async (req, res) => {
  if (req.method !== 'POST') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  try {
    const { video } = req.body;
    if (!video) {
      return res.status(400).json({ error: 'Geen video data ontvangen' });
    }

    // Vercel haalt de API sleutel op uit de instellingen
    const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY);
    const model = genAI.getGenerativeModel({ 
      model: "gemini-1.5-flash",
      generationConfig: { responseMimeType: "application/json" }
    });

    // Stuur de video (Base64) en de Rien van der Schaft instructie naar Gemini
    const response = await model.generateContent([
      {
        inlineData: {
          data: video,
          mimeType: "video/mp4"
        }
      },
      RIEN_VAN_DER_SCHAFT_PROMPT
    ]);

    const resultText = response.response.text();
    const resultJson = JSON.parse(resultText);

    return res.status(200).json(resultJson);

  } catch (error) {
    console.error("Error tijdens AI analyse:", error);
    return res.status(500).json({ error: "Er ging iets mis bij de AI verwerking: " + error.message });
  }
};
